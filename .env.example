# --- Public (client-safe; exposed to the browser bundle) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# --- Server-only secrets; never reference these with NEXT_PUBLIC_ ---
SUPABASE_SERVICE_ROLE_KEY=

# Firebase Admin SDK service account (server-only). Paste the private_key
# value with literal \n sequences; lib/firebase/admin.ts unescapes them.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
